# Helmio Agent — runs on the same host as supervisord.
# Bind address/port the agent listens on (panel connects here).
AGENT_PORT=8787
AGENT_HOST=0.0.0.0

# Shared secret. The panel must send this as "Authorization: Bearer <token>".
# Generate e.g.:  node -e "console.log(require('crypto').randomBytes(24).toString('hex'))"
AGENT_TOKEN=change-me

# How the agent reaches the LOCAL supervisord. Use EITHER a unix socket...
SUPERVISOR_SOCKET=/var/run/supervisor.sock
# ...or a TCP inet_http_server (leave SUPERVISOR_SOCKET empty to use these):
# SUPERVISOR_HOST=127.0.0.1
# SUPERVISOR_PORT=9001
SUPERVISOR_PATH=/RPC2
# Optional supervisor HTTP auth:
# SUPERVISOR_USER=
# SUPERVISOR_PASS=
