# Helmio backend
PORT=3001
# Frontend origin for CORS (Vite dev server)
CORS_ORIGIN=http://localhost:5173
# How often (ms) the realtime poller refreshes process info per subscribed server
POLL_INTERVAL_MS=3000
# Path to the JSON store that holds server definitions
DATA_DIR=./data

# Auth: secret used to sign session JWTs. If unset, a random secret is generated
# and persisted to DATA_DIR/.jwt-secret (fine for dev; set this in production).
JWT_SECRET=
# Session token lifetime (e.g. 12h, 7d, 30m)
JWT_TTL=12h
# Encryption key for secrets at rest (server passwords/keys, channel creds, etc.).
# Any string; folded to 32 bytes. If unset, a random key is generated and
# persisted to DATA_DIR/.secret-key. SET THIS IN PRODUCTION (and keep it safe —
# losing it makes stored secrets unrecoverable).
HELMIO_SECRET_KEY=

# Public base URL this backend is reachable at FROM target hosts. Baked into the
# generated eventlistener config so the listener can POST events back. Set this
# in production (defaults to http://localhost:PORT).
HELMIO_PUBLIC_URL=
# Background alert sweep cadence (ms): polls every server — even unwatched ones
# without the eventlistener — so notifications fire when nobody is looking.
# Set to 0 to disable (rely solely on the eventlistener push + viewer polling).
ALERT_POLL_INTERVAL_MS=30000
